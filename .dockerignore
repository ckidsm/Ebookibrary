# rsync --exclude-from 으로 사용. 단순 파일명도 매칭되도록 leading slash 명시.

# Git·메타
/.git
/.gitignore
/.editorconfig
/.dockerignore
/CLAUDE.md
/README.md

# 배포·헬퍼 스크립트 (NAS에서 실행 안 함)
/deploy.sh
/add_book.sh

# 옛 가이드·구버전 스크립트 (보존만, NAS에 안 보냄)
/_archive/

# 설계·기획 문서 — 내부용만 제외 (가이드는 배포 OK)
/docs/PHASE_B_PROPOSAL.md
/install-img/README.md

# 백엔드는 별도 컨테이너로 빌드·배포 — 정적 rsync에는 안 보냄
/kyobo-bridge/
/docker-compose.yml

# Mac 로컬 자동화 도구 — NAS 미전송
/book-capture/

# 빌드 도구·캐시 (모든 books/ 하위에서)
**/ocr_text/
**/verification_report.json
**/verification_report.md
**/batch_*.json
**/*.py
**/__pycache__/
**/*.BAK
**/*.bak
# pages_data.json / chapters_data.json — analyzed endpoint 페이지 카운트용 (NAS 동기화 허용)
# thumbs/ — UI 의 페이지별 미리보기 (NAS 동기화 허용)

# 시스템·임시
.DS_Store
*.swp
.vscode/
.idea/
